# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: <your-deployed-url>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Leaderboard (see README.md's Leaderboard section)
DATABASE_URL=
# Any long random string, e.g. `openssl rand -hex 32`. Must match the
# multiplayer server's MULTIPLAYER_SHARED_SECRET (server/.env.example).
MULTIPLAYER_SHARED_SECRET=
