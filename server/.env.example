# Comma-separated list of allowed browser Origin headers, e.g.
# https://royale.rocks,https://www.royale.rocks. Optional -- unset/empty
# allows any origin.
ALLOWED_ORIGINS=

# Leaderboard score reporting (see ../README.md's Leaderboard section).
# Both optional -- unset means online play works, scores just aren't
# recorded. MULTIPLAYER_SHARED_SECRET must match the site's.
MULTIPLAYER_SHARED_SECRET=
SCORES_SUBMIT_URL=
